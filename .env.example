# ============================================
#  Bling-Claude-ApexM  ·  Exemplo de configuração
# --------------------------------------------
#  Copie para `.env` e preencha com valores reais.
#  Nunca commite o `.env` real.
# ============================================

# API Bling (OAuth 2.0)
BLING_CLIENT_ID=<seu-client-id>
BLING_CLIENT_SECRET=<seu-client-secret>
BLING_DEPOSITO_ID=<id-do-deposito>

# API do fornecedor
SUPPLIER_API_URL=<url-da-api-do-fornecedor>
SUPPLIER_API_KEY=<sua-chave>

# Provedores de LLM (opcional — escolha um)
ANTHROPIC_API_KEY=<sua-chave-claude>
GEMINI_API_KEY=<sua-chave-gemini>

# Configuração
SYNC_INTERVAL_SECONDS=300
LOG_LEVEL=INFO